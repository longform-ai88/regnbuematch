{
  "name": "RegnbueMatch",
  "short_name": "RegnbueMatch",
  "id": "regnbuematch-pwa",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "orientation": "portrait",
  "background_color": "#a259c6",
  "theme_color": "#a259c6",
  "description": "Installerbar PWA for RegnbueMatch.",
  "icons": [
    {
      "src": "./icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icons/maskable-icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "./icons/apple-touch-icon.png",
      "sizes": "180x180",
      "type": "image/png"
    }
  ],
  "screenshots": [
    {
      "src": "./icons/splashscreen.png",
      "sizes": "1200x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "RegnbueMatch splashscreen"
    }
  ]
}
